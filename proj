def draw_boss():
    if not boss["active"]:
        return
    bx, by, bz = boss["pos"]

    # ── hull ──────────────────────────────────
    glColor3f(0.25, 0.25, 0.25)
    solid_box(bx, by, bz, 65, 65, 18)

    # ── under-belly detail ─────────────────────
    glColor3f(0.45, 0.10, 0.10)
    solid_box(bx, by, bz - 8, 30, 30, 6)

    # ── propellers (4 arms) ────────────────────
    ang = boss["propeller_angle"]
    for ox, oy in [(28, 28), (-28, 28), (28, -28), (-28, -28)]:
        # arm
        glColor3f(0.40, 0.40, 0.40)
        solid_box(bx + ox/2, by + oy/2, bz + 10, abs(ox), 6, 5)
        # spinning blades
        glPushMatrix()
        glTranslatef(bx + ox, by + oy, bz + 13)
        glRotatef(ang, 0, 0, 1)
        glColor3f(0.72, 0.72, 0.72)
        solid_box(0, 0, 0, 34, 6, 3)
        glRotatef(90, 0, 0, 1)
        solid_box(0, 0, 0, 34, 6, 3)
        glPopMatrix()

    # ── laser lock-on beam ─────────────────────
    if boss["laser_active"]:
        pulse = 0.5 + 0.5 * math.sin(boss["lock_timer"] * 0.25)
        glColor3f(1.0, pulse * 0.2, pulse * 0.2)
        glLineWidth(3.0 + pulse * 2)
        glBegin(GL_LINES)
        glVertex3f(bx, by, bz - 9)
        glVertex3f(*player["pos"])
        glEnd()
        glLineWidth(1.0)

    # ── boss HP pips ───────────────────────────
    for i in range(BOSS_MAX_HP):
        if i < boss["hp"]:
            glColor3f(0.9, 0.1, 0.9)
        else:
            glColor3f(0.2, 0.2, 0.2)
        glPushMatrix()
        glTranslatef(bx - 32 + i * 16, by + 40, bz + 18)
        glutSolidSphere(5, 6, 6)
        glPopMatrix()


