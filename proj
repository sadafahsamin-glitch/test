# ─────────────────────────────────────────────
# TILE DAMAGE
# ─────────────────────────────────────────────
def damage_tile_at(wx, wy, wz, dmg=1):
    for ri, r in enumerate(rooftops):
        half = r["size"] / 2.0
        if abs(wx - r["x"]) < half and abs(wy - r["y"]) < half:
            if abs(wz - r["z"]) < 25:
                tw  = r["size"] / TILE_N
                col = int((wx - (r["x"] - half)) / tw)
                row = int((wy - (r["y"] - half)) / tw)
                col = max(0, min(TILE_N-1, col))
                row = max(0, min(TILE_N-1, row))
                tiles[ri][row][col] = max(0, tiles[ri][row][col] - dmg)
                return True
    return False


def tile_hp_at(wx, wy, wz):
    """Return HP of tile under position, or -1 if not over any rooftop."""
    for ri, r in enumerate(rooftops):
        half = r["size"] / 2.0
        if abs(wx - r["x"]) < half and abs(wy - r["y"]) < half:
            if abs(wz - r["z"]) < 30:
                tw  = r["size"] / TILE_N
                col = int((wx - (r["x"] - half)) / tw)
                row = int((wy - (r["y"] - half)) / tw)
                col = max(0, min(TILE_N-1, col))
                row = max(0, min(TILE_N-1, row))
                return tiles[ri][row][col], r["z"]
    return -1, 0


# ─────────────────────────────────────────────
# PHYSICS / LOGIC
# ─────────────────────────────────────────────
def update_player():
    px, py, pz = player["pos"]
    fx, fy = player["facing"][0], player["facing"][1]
    rx, ry = -fy, fx                         # right vector

    # horizontal input
    mvx, mvy = 0.0, 0.0
    if 119 in keys_held or 87 in keys_held:  # w/W
        mvx += fx; mvy += fy
    if 115 in keys_held or 83 in keys_held:  # s/S
        mvx -= fx; mvy -= fy
    if 97  in keys_held or 65 in keys_held:  # a/A
        mvx -= rx; mvy -= ry
    if 100 in keys_held or 68 in keys_held:  # d/D
        mvx += rx; mvy += ry
    mag = math.sqrt(mvx*mvx + mvy*mvy + 1e-9)
    if mag > 0:
        player["pos"][0] += mvx/mag * PLAYER_SPEED * dt
        player["pos"][1] += mvy/mag * PLAYER_SPEED * dt

    # vertical
    if not player["on_ground"] or player["vel"][2] > 0:
        player["vel"][2] -= GRAVITY
        player["pos"][2] += player["vel"][2]

    # landing check
    hp_val, land_z = tile_hp_at(player["pos"][0], player["pos"][1], player["pos"][2])
    if hp_val > 0 and player["vel"][2] <= 0:
        player["on_ground"] = True
        player["vel"][2]    = 0.0
        player["pos"][2]    = land_z + 13.0
    elif not hook["attached"]:
        player["on_ground"] = False

    # fall-through broken tile
    if hp_val == 0:
        player["on_ground"] = False

    # death floor
    if player["pos"][2] < -80:
        die()

    if player["iframes"] > 0:
        player["iframes"] -= 1


def update_hook():
    if not hook["active"]:
        return

    if not hook["attached"]:
        for i in range(3):   # sub-steps for accuracy
            hook["pos"][0] += hook["dir"][0] * HOOK_SPEED / 3
            hook["pos"][1] += hook["dir"][1] * HOOK_SPEED / 3
            hook["pos"][2] += hook["dir"][2] * HOOK_SPEED / 3

        # max range
        ddx = hook["pos"][0] - player["pos"][0]
        ddy = hook["pos"][1] - player["pos"][1]
        ddz = hook["pos"][2] - player["pos"][2]
        if math.sqrt(ddx*ddx+ddy*ddy+ddz*ddz) > HOOK_RANGE:
            hook["active"] = False
            return

        # attach to rooftop?
        for ri, r in enumerate(rooftops):
            half = r["size"] / 2.0
            if (abs(hook["pos"][0]-r["x"]) < half and
                    abs(hook["pos"][1]-r["y"]) < half and
                    abs(hook["pos"][2]-r["z"]) < 30):
                hook["attached"] = True
                hook["target"]   = [r["x"], r["y"], float(r["z"])]
                return

        # attach to anchor?
        for a in anchor_pts:
            dx = hook["pos"][0]-a["x"]
            dy = hook["pos"][1]-a["y"]
            dz = hook["pos"][2]-a["z"]
            if math.sqrt(dx*dx+dy*dy+dz*dz) < 28:
                hook["attached"] = True
                hook["target"]   = [a["x"], a["y"], a["z"]]
                return

    else:
        # pull player toward anchor
        tx, ty, tz = hook["target"]
        dx = tx - player["pos"][0]
        dy = ty - player["pos"][1]
        dz = tz - player["pos"][2]
        dist = math.sqrt(dx*dx+dy*dy+dz*dz)
        if dist > 8:
            pull = min(9.0, dist * 0.14)
            player["pos"][0] += dx/dist * pull
            player["pos"][1] += dy/dist * pull
            player["pos"][2] += dz/dist * pull
            player["vel"][2]  = 0.0
            player["on_ground"] = False
        else:
            hook["active"] = hook["attached"] = False


def update_projectiles():
    global projectiles
    alive = []
    for p in projectiles:
        p["x"] += (p["dx"] + wind[0]) * dt * 60
        p["y"] += (p["dy"] + wind[1]) * dt * 60
        p["z"] +=  p["dz"]            * dt * 60
        p["life"] -= 1
        if p["life"] <= 0:
            continue

        hit = False

        # hit player
        if p.get("enemy"):
            if player["iframes"] == 0:
                dx = p["x"]-player["pos"][0]
                dy = p["y"]-player["pos"][1]
                dz = p["z"]-player["pos"][2]
                if math.sqrt(dx*dx+dy*dy+dz*dz) < 18:
                    dmg = 2 if p.get("oneshot") else 1
                    player["hp"] -= dmg
                    player["iframes"] = 40
                    if player["hp"] <= 0:
                        die()
                    hit = True

        # hit tile
        if not hit:
            if damage_tile_at(p["x"], p["y"], p["z"]):
                hit = True

        # hit enemy (player bullets)
        if not hit and not p.get("enemy"):
            for e in enemies:
                if not e["alive"]:
                    continue
                dx = p["x"]-e["pos"][0]
                dy = p["y"]-e["pos"][1]
                dz = p["z"]-e["pos"][2]
                if math.sqrt(dx*dx+dy*dy+dz*dz) < 18:
                    e["hp"] -= 1
                    if e["hp"] <= 0:
                        e["alive"] = False
                        global kills
                        kills += 1
                    hit = True
                    break

        # hit boss
        if not hit and not p.get("enemy") and boss["active"]:
            dx = p["x"]-boss["pos"][0]
            dy = p["y"]-boss["pos"][1]
            dz = p["z"]-boss["pos"][2]
            if math.sqrt(dx*dx+dy*dy+dz*dz) < 55:
                boss["hp"] -= 1
                hit = True
                if boss["hp"] <= 0:
                    boss["active"] = False
                    global game_state
                    game_state = "win"

        if not hit:
            alive.append(p)

    projectiles = alive


def update_enemies():
    for e in enemies:
        if not e["alive"]:
            continue
        e["shoot_timer"] -= 1
        if e["shoot_timer"] <= 0:
            dx = player["pos"][0]-e["pos"][0]
            dy = player["pos"][1]-e["pos"][1]
            dz = player["pos"][2]-e["pos"][2]
            dist = math.sqrt(dx*dx+dy*dy+dz*dz + 1e-9)
            projectiles.append({
                "x": e["pos"][0], "y": e["pos"][1], "z": e["pos"][2],
                "dx": dx/dist*3.5, "dy": dy/dist*3.5, "dz": dz/dist*3.5,
                "life": 130, "enemy": True,
            })
            e["shoot_timer"] = random.randint(85, 145)


def update_boss():
    if not boss["active"]:
        return

    boss["propeller_angle"] = (boss["propeller_angle"] + 16) % 360

    if boss["state"] == "idle":
        boss["move_timer"] -= 1
        if boss["move_timer"] <= 0:
            boss["state"]        = "locking"
            boss["lock_timer"]   = 120
            boss["laser_active"] = True

    elif boss["state"] == "locking":
        boss["lock_timer"] -= 1
        if boss["lock_timer"] <= 0:
            # FIRE one-shot sniper round
            dx = player["pos"][0]-boss["pos"][0]
            dy = player["pos"][1]-boss["pos"][1]
            dz = player["pos"][2]-boss["pos"][2]
            dist = math.sqrt(dx*dx+dy*dy+dz*dz + 1e-9)
            projectiles.append({
                "x": boss["pos"][0], "y": boss["pos"][1], "z": boss["pos"][2]-9,
                "dx": dx/dist*9, "dy": dy/dist*9, "dz": dz/dist*9,
                "life": 250, "enemy": True, "oneshot": True,
            })
            boss["laser_active"] = False
            boss["state"]        = "moving"
            boss["target_pos"]   = [
                random.uniform(-320, 320),
                random.uniform(-320, 320),
                random.uniform(430,  560),
            ]

    elif boss["state"] == "moving":
        tx, ty, tz = boss["target_pos"]
        dx = tx-boss["pos"][0]; dy = ty-boss["pos"][1]; dz = tz-boss["pos"][2]
        dist = math.sqrt(dx*dx+dy*dy+dz*dz + 1e-9)
        if dist > 6:
            boss["pos"][0] += dx/dist * 4.5
            boss["pos"][1] += dy/dist * 4.5
            boss["pos"][2] += dz/dist * 4.5
        else:
            boss["state"]      = "idle"
            boss["move_timer"] = 85


def check_wave_end():
    global wave, game_state
    alive = sum(1 for e in enemies if e["alive"])
    if alive == 0 and not boss["active"]:
        if wave >= 3:
            boss["active"] = True
            boss["hp"]     = BOSS_MAX_HP
            boss["pos"]    = [0.0, 0.0, 520.0]
            boss["state"]  = "idle"
            boss["move_timer"] = 80
            boss["laser_active"] = False
        else:
            wave += 1
            wind[0] = random.uniform(-0.30, 0.30)
            wind[1] = random.uniform(-0.18, 0.18)
            spawn_enemies(wave)


def die():
    global game_state
    game_state = "dead"


def fire_player():
    fx, fy, fz = player["facing"]
    projectiles.append({
        "x":  player["pos"][0] + fx * 14,
        "y":  player["pos"][1] + fy * 14,
        "z":  player["pos"][2] + 4,
        "dx": fx * 7.0,
        "dy": fy * 7.0,
        "dz": fz * 7.0 + 0.05,
        "life": 110, "enemy": False,
    })


def update_all():
    if game_state != "playing":
        return
    update_player()
    update_hook()
    update_projectiles()
    update_enemies()
    update_boss()
    check_wave_end()


