def draw_sky():
    """Full-screen gradient sky — depth write OFF so it never occludes 3-D.
    FIX: was incorrectly restoring state; now uses push/pop for all state."""
    glDisable(GL_DEPTH_TEST)
    glDisable(GL_FOG)
    glDisable(GL_LIGHTING)
    glDepthMask(GL_FALSE)               # FIX: don't pollute depth buffer with sky

    glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity()
    gluOrtho2D(0, 1, 0, 1)
    glMatrixMode(GL_MODELVIEW);  glPushMatrix(); glLoadIdentity()
    glBegin(GL_QUADS)
    glColor3f(0.70, 0.76, 0.86)         # Horizon warm haze
    glVertex2f(0, 0); glVertex2f(1, 0)
    glColor3f(0.28, 0.42, 0.72)         # Zenith deep blue
    glVertex2f(1, 1); glVertex2f(0, 1)
    glEnd()
    glPopMatrix()
    glMatrixMode(GL_PROJECTION); glPopMatrix()
    glMatrixMode(GL_MODELVIEW)

    glDepthMask(GL_TRUE)
    glEnable(GL_DEPTH_TEST)
    glEnable(GL_FOG)
    glEnable(GL_LIGHTING)


