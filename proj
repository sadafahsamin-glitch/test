# INPUT
# ─────────────────────────────────────────────
def keyboard_down(key, x, y):
    code = key[0] if isinstance(key, bytes) else ord(key)
    keys_held.add(code)
    ch = chr(code).lower()

    if ch == ' ':
        if player["on_ground"]:
            player["vel"][2]    = JUMP_VEL
            player["on_ground"] = False

    elif ch == 'e':
        hook["active"]   = True
        hook["attached"] = False
        hook["pos"]      = player["pos"][:]
        fx, fy = player["facing"][0], player["facing"][1]
        raw = [fx, fy, 0.25]
        m   = math.sqrt(sum(v*v for v in raw))
        hook["dir"] = [v/m for v in raw]

    elif ch == 'q':
        hook["active"] = hook["attached"] = False

    elif ch == 'f':
        fire_player()

    elif ch == 'l':
        player["angle"] -= 12
        a = math.radians(player["angle"])
        player["facing"] = [math.cos(a), math.sin(a), 0.0]

    elif ch == 'j':
        player["angle"] += 12
        a = math.radians(player["angle"])
        player["facing"] = [math.cos(a), math.sin(a), 0.0]

    elif ch == 'r' and game_state in ("dead", "win"):
        restart()


def keyboard_up(key, x, y):
    code = key[0] if isinstance(key, bytes) else ord(key)
    keys_held.discard(code)


def restart():
    global game_state, wave, kills, projectiles
    game_state = "playing"
    wave = 1; kills = 0
    projectiles = []
    hook["active"] = hook["attached"] = False

    boss.update({"active": False, "hp": BOSS_MAX_HP, "laser_active": False,
                 "state": "idle", "move_timer": 90, "propeller_angle": 0.0})

    player.update({"hp": 5, "vel": [0.0, 0.0, 0.0],
                   "on_ground": True, "iframes": 0, "angle": 0.0,
                   "facing": [1.0, 0.0, 0.0]})
    s = rooftops[12]
    player["pos"] = [s["x"], s["y"], s["z"] + 15.0]

    for ri in range(len(rooftops)):
        tiles[ri] = [[TILE_HP_MAX]*TILE_N for _ in range(TILE_N)]

    wind[:] = [0.18, 0.06]
    spawn_enemies(wave)


