def make_rooftop(cx, cy, sx, sy, top, gx, gy, rgb):
    tiles = [[{"hp": 3, "dead": False} for _ in range(gx)] for _ in range(gy)]
    return {"cx": cx, "cy": cy, "sx": sx, "sy": sy, "top": top,
            "gx": gx, "gy": gy, "tiles": tiles, "color": rgb}


def spawn_hostile(x, y, z):
    return {
        "x": float(x), "y": float(y), "z": float(z),
        "hp": 50, "hp_max": 50,
        "fire_timer":    random.uniform(2.0, 4.0),
        "fire_interval": random.uniform(4.0, 6.5),
        "alive": True,
    }


def make_decor(seed):
    rng = random.Random(seed)
    decor = []
    for i in range(50):
        ang = (i / 50.0) * 2 * math.pi + rng.uniform(-0.06, 0.06)
        r   = rng.uniform(1500, 2500)
        cx  = math.cos(ang) * r
        cy  = math.sin(ang) * r
        sx  = rng.uniform(80, 220)
        sy  = rng.uniform(80, 220)
        h   = rng.uniform(180, 720)
        c   = (rng.uniform(0.25, 0.45),
               rng.uniform(0.25, 0.45),
               rng.uniform(0.35, 0.55))
        decor.append((cx, cy, sx, sy, h, c))
    return decor


