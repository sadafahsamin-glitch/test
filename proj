# ─── Queries ────────────────────────────────────────────────────────
def xy_inside(R, x, y):
    return (R["cx"]-R["sx"] <= x <= R["cx"]+R["sx"] and
            R["cy"]-R["sy"] <= y <= R["cy"]+R["sy"])


def tile_index(R, x, y):
    u = (x - (R["cx"]-R["sx"])) / (2*R["sx"])
    v = (y - (R["cy"]-R["sy"])) / (2*R["sy"])
    ix = int(clampf(math.floor(u*R["gx"]), 0, R["gx"]-1))
    iy = int(clampf(math.floor(v*R["gy"]), 0, R["gy"]-1))
    return ix, iy


def roof_top_at(x, y, upper_z):
    best = None
    for R in rooftops:
        if not xy_inside(R, x, y): continue
        if R["top"] > upper_z + 2: continue
        ix, iy = tile_index(R, x, y)
        if R["tiles"][iy][ix]["dead"]: continue
        if best is None or R["top"] > best:
            best = R["top"]
    return best


# ─── Shooting ───────────────────────────────────────────────────────
def spawn_bullet(pos, direction, dmg, from_player, speed=BULLET_SPEED):
    projectiles.append({
        "pos":   list(pos),
        "vel":   [direction[0]*speed, direction[1]*speed, direction[2]*speed],
        "life":  2.2,
        "dmg":   dmg,
        "from_player": from_player,
    })


def fire_weapon():
    w = weapons[player["weapon"]]
    if w["cd"] > 0.0: return
    w["cd"] = 1.0 / w["rate"]
    origin = [player["pos"][0], player["pos"][1], player["pos"][2] + 30.0]
    f = facing_vec()
    for _ in range(w["pellets"]):
        d = list(f)
        if w["spread"] > 0:
            d[0] += random.uniform(-w["spread"], w["spread"])
            d[1] += random.uniform(-w["spread"], w["spread"])
            d[2] += random.uniform(-w["spread"], w["spread"])
            d = unit3(d)
        spawn_bullet(origin, d, w["dmg"], True)


# ─── Damage / Explosion ─────────────────────────────────────────────
def damage_player(amount):
    """FIX: properly track lives. Game over when lives reach 0."""
    player["hp"] -= amount
    player["hit_flash"] = 0.25          # NEW: trigger damage flash
    if player["hp"] <= 0:
        player["lives"] -= 1
        if player["lives"] <= 0:
            player["hp"] = 0            # let tick_game detect game over
            return
        # Still have lives — respawn
        if checkpoint["active"]:
            player["pos"] = [checkpoint["pos"][0], checkpoint["pos"][1], checkpoint["pos"][2] + 10]
        else:
            player["pos"] = list(player["spawn"])
        player["vel"] = [0.0, 0.0, 0.0]
        player["hp"]  = player["hp_max"]
        player["on_zipline"] = False


def explode_prop(p):
    if p["exploded"]: return
    p["exploded"] = True
    r = p["r"]
    for h in hostiles:
        if not h["alive"]: continue
        if dist3([h["x"],h["y"],h["z"]], p["pos"]) < r:
            h["hp"] -= 80
            if h["hp"] <= 0: h["alive"] = False
    if boss and boss["alive"] and dist3(boss["pos"], p["pos"]) < r:
        boss["hp"] -= 50
        if boss["hp"] <= 0: boss["alive"] = False
    pd = dist3(player["pos"], p["pos"])
    if pd < r:
        damage_player((1.0 - pd/r) * 70)
    for q in props:
        if q is p or q["exploded"]: continue
        if dist3(q["pos"], p["pos"]) < r:
            q["hp"] = 0


# ─── Updates ────────────────────────────────────────────────────────
def update_player(dt):
    if player["on_zipline"]:
        Z = ziplines[player["zip_idx"]]
        ax, ay, az = Z["a"]; bx, by, bz = Z["b"]
        length = math.sqrt((bx-ax)**2 + (by-ay)**2 + (bz-az)**2)
        speed_t = 360.0 / max(length, 1.0)
        player["zip_t"] += player["zip_dir"] * speed_t * dt
        if player["zip_t"] >= 1.0 or player["zip_t"] <= 0.0:
            player["zip_t"] = clampf(player["zip_t"], 0.0, 1.0)
            t = player["zip_t"]
            player["pos"] = [ax+(bx-ax)*t, ay+(by-ay)*t, az+(bz-az)*t + 15]
            player["on_zipline"] = False
        else:
            t = player["zip_t"]
            player["pos"] = [ax+(bx-ax)*t, ay+(by-ay)*t, az+(bz-az)*t + 15]
        player["vel"] = [0.0, 0.0, 0.0]
        return

    ry = math.radians(player["facing"])
    fwd    = [ math.cos(ry),  math.sin(ry), 0.0]
    strafe = [ math.sin(ry), -math.cos(ry), 0.0]
    wish  = [0.0, 0.0, 0.0]
    if b"w" in keys_held: wish = [wish[0]+fwd[0],    wish[1]+fwd[1],    0]
    if b"s" in keys_held: wish = [wish[0]-fwd[0],    wish[1]-fwd[1],    0]
    if b"d" in keys_held: wish = [wish[0]+strafe[0], wish[1]+strafe[1], 0]
    if b"a" in keys_held: wish = [wish[0]-strafe[0], wish[1]-strafe[1], 0]
    m = math.sqrt(wish[0]*wish[0] + wish[1]*wish[1])
    if m > 0.01:
        wish[0]/=m; wish[1]/=m
    player["vel"][0] = wish[0] * MOVE_SPEED
    player["vel"][1] = wish[1] * MOVE_SPEED

    if b" " in keys_held and (player["grounded"] or player["coyote"] > 0.0):
        player["vel"][2] = JUMP_V
        player["grounded"] = False
        player["coyote"] = 0.0
        keys_held.discard(b" ")

    player["vel"][2] += GRAVITY * dt

    nx = player["pos"][0] + player["vel"][0]*dt
    ny = player["pos"][1] + player["vel"][1]*dt
    nz = player["pos"][2] + player["vel"][2]*dt

    top = roof_top_at(nx, ny, player["pos"][2] + 5)
    was_grounded = player["grounded"]
    player["grounded"] = False
    if top is not None and nz <= top + 0.1 and player["vel"][2] <= 0:
        nz = top + 0.1
        player["vel"][2] = 0.0
        player["grounded"] = True

    if was_grounded and not player["grounded"]:
        player["coyote"] = COYOTE_TIME
    elif player["coyote"] > 0:
        player["coyote"] -= dt

    player["pos"] = [nx, ny, nz]

    if player["pos"][2] < FALL_DEATH_Z:
        damage_player(9999)

    if not checkpoint["active"] and dist3(player["pos"], checkpoint["pos"]) < 55:
        checkpoint["active"] = True
        player["spawn"] = list(checkpoint["pos"])

    if portal["active"] and dist3(player["pos"], portal["pos"]) < 70:
        advance_level()

    # Decay hit flash
    if player["hit_flash"] > 0:
        player["hit_flash"] -= dt


def update_bullets(dt):
    dead = []
    for b in projectiles:
        prev = list(b["pos"])
        b["pos"][0] += b["vel"][0]*dt
        b["pos"][1] += b["vel"][1]*dt
        b["pos"][2] += b["vel"][2]*dt
        b["life"] -= dt
        if b["life"] <= 0:
            dead.append(b); continue

        hit = False
        for R in rooftops:
            dz = b["pos"][2] - prev[2]
            if abs(dz) < 1e-5: continue
            t = (R["top"] - prev[2]) / dz
            if t < 0 or t > 1: continue
            hx = prev[0] + (b["pos"][0]-prev[0])*t
            hy = prev[1] + (b["pos"][1]-prev[1])*t
            if not xy_inside(R, hx, hy): continue
            ix, iy = tile_index(R, hx, hy)
            tile = R["tiles"][iy][ix]
            if tile["dead"]: continue
            if (b["from_player"] and player["grounded"] and
                xy_inside(R, player["pos"][0], player["pos"][1]) and
                abs(player["pos"][2] - R["top"]) < 2.0):
                pix, piy = tile_index(R, player["pos"][0], player["pos"][1])
                if pix == ix and piy == iy:
                    hit = True
                    break
            tile["hp"] -= b["dmg"]
            if tile["hp"] <= 0:
                tile["dead"] = True
            hit = True
            break
        if hit:
            dead.append(b); continue

        if b["from_player"]:
            for h in hostiles:
                if not h["alive"]: continue
                if dist3(b["pos"], [h["x"], h["y"], h["z"]]) < 22:
                    h["hp"] -= b["dmg"]
                    if h["hp"] <= 0:
                        h["alive"] = False
                        player["kills"] += 1
                    hit = True; break
            if hit:
                dead.append(b); continue
            if boss and boss["alive"] and dist3(b["pos"], boss["pos"]) < 32:
                boss["hp"] -= b["dmg"]
                if boss["hp"] <= 0: boss["alive"] = False
                dead.append(b); continue
            for p in props:
                if p["exploded"]: continue
                if dist3(b["pos"], p["pos"]) < 22:
                    p["hp"] -= b["dmg"]
                    p["flash"] = 0.15
                    if p["hp"] <= 0: explode_prop(p)
                    dead.append(b); break
        else:
            if dist3(b["pos"], [player["pos"][0], player["pos"][1], player["pos"][2]+25]) < 25:
                damage_player(b["dmg"])
                dead.append(b)

    for d in dead:
        if d in projectiles: projectiles.remove(d)


def update_enemies(dt):
    for h in hostiles:
        if not h["alive"]: continue
        d = dist3([h["x"],h["y"],h["z"]], player["pos"])
        if d > 1100: continue
        h["fire_timer"] -= dt
        if h["fire_timer"] <= 0:
            dx = player["pos"][0] - h["x"]
            dy = player["pos"][1] - h["y"]
            dz = (player["pos"][2] + 25) - h["z"]
            m = max(math.sqrt(dx*dx+dy*dy+dz*dz), 1e-3)
            spawn_bullet([h["x"], h["y"], h["z"]+10], [dx/m, dy/m, dz/m], 8, False, speed=520)
            h["fire_timer"] = h["fire_interval"]


def update_boss(dt):
    global boss
    if not boss or not boss["alive"]: return
    boss["timer"] -= dt

    if boss["state"] == "AIM":
        if boss["timer"] <= 0:
            dx = player["pos"][0] - boss["pos"][0]
            dy = player["pos"][1] - boss["pos"][1]
            dz = (player["pos"][2]+25) - boss["pos"][2]
            m = max(math.sqrt(dx*dx+dy*dy+dz*dz), 1e-3)
            spawn_bullet(boss["pos"], [dx/m, dy/m, dz/m], 75, False, speed=1800)
            boss["state"] = "FIRE"; boss["timer"] = 0.25
    elif boss["state"] == "FIRE":
        if boss["timer"] <= 0:
            ang = random.uniform(0, 2*math.pi)
            r   = random.uniform(220.0, 360.0)
            boss["move_tgt"] = [350.0 + math.cos(ang)*r,
                                560.0 + math.sin(ang)*r,
                                random.uniform(340.0, 420.0)]
            boss["state"] = "MOVE"; boss["timer"] = 1.4
    else:
        tx, ty, tz = boss["move_tgt"]
        bx, by, bz = boss["pos"]
        dx, dy, dz = tx-bx, ty-by, tz-bz
        m = math.sqrt(dx*dx+dy*dy+dz*dz)
        if m > 0.5:
            step = min(m, 360.0 * dt)
            boss["pos"] = [bx + dx/m*step, by + dy/m*step, bz + dz/m*step]
        if boss["timer"] <= 0:
            boss["state"] = "AIM"; boss["timer"] = 1.5


def update_props(dt):
    for p in props:
        if p["exploded"]: continue
        if p["flash"] > 0: p["flash"] -= dt
        if p["hp"] <= 0: explode_prop(p)


def update_weapons(dt):
    for w in weapons:
        if w["cd"] > 0: w["cd"] -= dt
    if mouse_down:
        fire_weapon()


def update_pulse(dt):
    global pulse_size, pulse_grow
    if pulse_grow:
        pulse_size += dt*0.6
        if pulse_size >= 1.2: pulse_grow = False
    else:
        pulse_size -= dt*0.6
        if pulse_size <= 0.85: pulse_grow = True


