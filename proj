# DRAW HELPERS
# ─────────────────────────────────────────────
def solid_box(cx, cy, cz, sx, sy, sz):
    glPushMatrix()
    glTranslatef(cx, cy, cz)
    glScalef(sx, sy, sz)
    glutSolidCube(1.0)
    glPopMatrix()

def draw_rooftops_scene():
    for ri, r in enumerate(rooftops):
        half = r["size"] / 2.0
        tw   = r["size"] / TILE_N

        # ── building body ──────────────────────────
        glColor3f(0.13, 0.13, 0.38)
        solid_box(r["x"], r["y"], r["z"] / 2.0,
                  r["size"], r["size"], r["z"])

        # ── roof tiles ─────────────────────────────
        for row in range(TILE_N):
            for col in range(TILE_N):
                hp = tiles[ri][row][col]
                if hp <= 0:
                    continue
                frac = hp / TILE_HP_MAX
                glColor3f(0.22 + 0.12*frac, 0.22 + 0.08*frac, 0.52 + 0.28*frac)

                tx = r["x"] - half + col * tw + tw / 2
                ty = r["y"] - half + row * tw + tw / 2
                tz = r["z"] + 2.0

                glBegin(GL_QUADS)
                glNormal3f(0, 0, 1)
                glVertex3f(tx - tw/2 + 1, ty - tw/2 + 1, tz)
                glVertex3f(tx + tw/2 - 1, ty - tw/2 + 1, tz)
                glVertex3f(tx + tw/2 - 1, ty + tw/2 - 1, tz)
                glVertex3f(tx - tw/2 + 1, ty + tw/2 - 1, tz)
                glEnd()

                # tile edges (cracks between tiles)
                glColor3f(0.08, 0.08, 0.22)
                glBegin(GL_LINE_LOOP)
                glVertex3f(tx - tw/2 + 1, ty - tw/2 + 1, tz + 0.5)
                glVertex3f(tx + tw/2 - 1, ty - tw/2 + 1, tz + 0.5)
                glVertex3f(tx + tw/2 - 1, ty + tw/2 - 1, tz + 0.5)
                glVertex3f(tx - tw/2 + 1, ty + tw/2 - 1, tz + 0.5)
                glEnd()


def draw_anchors():
