        glColor3fv(col)
        glBegin(GL_QUADS)
        glVertex3f(cx-sx, cy-sy, h); glVertex3f(cx+sx, cy-sy, h)
        glVertex3f(cx+sx, cy+sy, h); glVertex3f(cx-sx, cy+sy, h)
        glEnd()


# ─── HUD drawing (semi-transparent backgrounds, proper depth state) ──
def hud_quad(x0, y0, x1, y1, r, g, b, a):
    """Draw a 2-D filled quad in screen space with optional alpha."""
    glColor4f(r, g, b, a)
    glBegin(GL_QUADS)
    glVertex2f(x0, y0); glVertex2f(x1, y0)
    glVertex2f(x1, y1); glVertex2f(x0, y1)
    glEnd()


def draw_hud():
    glDisable(GL_LIGHTING)
    glDisable(GL_DEPTH_TEST)
    glDisable(GL_FOG)
    glDepthMask(GL_FALSE)               # FIX: HUD never writes to depth

    glEnable(GL_BLEND)
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA)

    glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity()
    gluOrtho2D(0, WIN_W, 0, WIN_H)
    glMatrixMode(GL_MODELVIEW);  glPushMatrix(); glLoadIdentity()

    # ── Damage vignette flash ────────────────────────────────────────
    if player["hit_flash"] > 0:
        strength = clampf(player["hit_flash"] / 0.25, 0.0, 1.0) * 0.45
        hud_quad(0, 0, WIN_W, WIN_H, 0.85, 0.05, 0.05, strength)

    # ── Crosshair ────────────────────────────────────────────────────
    cx2, cy2 = WIN_W/2, WIN_H/2
    glColor4f(1, 1, 1, 0.88)
    glEnable(GL_LINE_SMOOTH)
    glHint(GL_LINE_SMOOTH_HINT, GL_NICEST)
    glLineWidth(1.5)
    glBegin(GL_LINES)
    glVertex2f(cx2 - 12, cy2); glVertex2f(cx2 - 3, cy2)
    glVertex2f(cx2 +  3, cy2); glVertex2f(cx2 + 12, cy2)
    glVertex2f(cx2, cy2 - 12); glVertex2f(cx2, cy2 - 3)
    glVertex2f(cx2, cy2 +  3); glVertex2f(cx2, cy2 + 12)
    glEnd()
    glDisable(GL_LINE_SMOOTH)
    glLineWidth(1.0)

    # ── Player HP bar (semi-transparent background) ──────────────────
    hfrac = clampf(player["hp"] / player["hp_max"], 0, 1)
    hud_quad(18, 18, 322, 52, 0.05, 0.05, 0.08, 0.72)      # FIX: alpha bg
    hud_quad(20, 20, 20 + 300*hfrac, 50,
             1.0 - hfrac, hfrac * 0.9, 0.18, 0.92)
    # Highlight stripe
    hud_quad(20, 45, 20 + 300*hfrac, 50,
             min(1.0,(1-hfrac)+0.5), min(1.0,hfrac*0.9+0.4), 0.55, 0.65)

    # ── Lives pips ──────────────────────────────────────────────────
    for i in range(MAX_LIVES):
        filled = i < player["lives"]
        if filled:
            hud_quad(20 + i*22, 55, 38 + i*22, 70, 0.25, 0.85, 0.35, 0.90)
        else:
            hud_quad(20 + i*22, 55, 38 + i*22, 70, 0.35, 0.10, 0.10, 0.70)

    # ── Boss bar ─────────────────────────────────────────────────────
    if boss and boss["alive"]:
        bfrac = clampf(boss["hp"]/boss["hp_max"], 0, 1)
        hud_quad(WIN_W/2-202, WIN_H-44, WIN_W/2+202, WIN_H-18,
                 0.05, 0.05, 0.08, 0.78)
        hud_quad(WIN_W/2-200, WIN_H-42, WIN_W/2-200 + 400*bfrac, WIN_H-20,
                 0.88, 0.10, 0.10, 0.95)

    glPopMatrix(); glMatrixMode(GL_PROJECTION); glPopMatrix()
    glMatrixMode(GL_MODELVIEW)

    # ── Text overlays ────────────────────────────────────────────────
    w = weapons[player["weapon"]]
    hud_print(20,  76, f"HP {player['hp']}/{player['hp_max']}")
    hud_print(WIN_W - 260, 30, f"[{player['weapon']+1}] {w['name']}")
    hud_print(20, WIN_H - 30, f"Kills: {player['kills']}")
    hud_print(20, WIN_H - 58, f"LEVEL {current_level + 1} / {NUM_LEVELS}",
              rgb=(0.65, 0.88, 1.0))

    enemies_left = sum(1 for h in hostiles if h["alive"])
    if current_level < NUM_LEVELS - 1:
        if enemies_left > 0:
            hud_print(20, WIN_H - 88, f"Eliminate hostiles: {enemies_left} remaining")
        else:
            hud_print(20, WIN_H - 88, "Reach the blue portal!", rgb=(0.35, 0.88, 1.0))
    else:
        if boss and boss["alive"]:
            hud_print(20, WIN_H - 88, "Destroy the SNIPER DRONE")
        elif game_won:
            hud_print(WIN_W/2 - 90, WIN_H/2 + 80, "*** VICTORY ***",
                      rgb=(0.35, 1.0, 0.35))
            hud_print(WIN_W/2 - 110, WIN_H/2 + 50,
                      "Press R to play again", rgb=(0.65, 1.0, 0.65))

    if boss and boss["alive"]:
        hud_print(WIN_W/2 - 60, WIN_H - 62, "SNIPER DRONE", rgb=(1, 0.88, 0.88))

    if not player["on_zipline"]:
        for z in ziplines:
            if dist3(player["pos"], z["a"]) < 60 or dist3(player["pos"], z["b"]) < 60:
                hud_print(WIN_W/2 - 90, WIN_H/2 - 42, "[E] ride zipline", rgb=(1, 0.88, 0.38))
                break
    if not checkpoint["active"] and dist3(player["pos"], checkpoint["pos"]) < 80:
        hud_print(WIN_W/2 - 130, WIN_H/2 - 68, "Step on pad to save checkpoint",
                  rgb=(0.35, 1.0, 0.35))
    if not game_active:
        hud_print(WIN_W/2 - 140, WIN_H/2 + 40, "GAME OVER -- press R to restart",
                  rgb=(1.0, 0.45, 0.45))

    glDisable(GL_BLEND)
    glDepthMask(GL_TRUE)
    glEnable(GL_DEPTH_TEST)
    glEnable(GL_FOG)
    glEnable(GL_LIGHTING)


# ─── Camera Setup ───────────────────────────────────────────────────
def setup_camera():
    glMatrixMode(GL_PROJECTION); glLoadIdentity()
    gluPerspective(PERSPECTIVE_FOV, WIN_W / WIN_H, 1.0, 4000.0)
    glMatrixMode(GL_MODELVIEW);  glLoadIdentity()

    if cam["mode"] == "cockpit":
        ex, ey, ez = player["pos"][0], player["pos"][1], player["pos"][2] + 30
        f = facing_vec()
        lx, ly, lz = ex + f[0]*100, ey + f[1]*100, ez + f[2]*100
        gluLookAt(ex, ey, ez, lx, ly, lz, 0, 0, 1)
    else:
        oa = cam["orbit_angle"]
        ex = cam["orbit_radius"] * math.cos(oa)
        ey = cam["orbit_radius"] * math.sin(oa)
        gluLookAt(ex, ey, cam["elevation"],
                  player["pos"][0], player["pos"][1], player["pos"][2],
                  0, 0, 1)


# ─── Input Handlers ─────────────────────────────────────────────────
def keyboard_handler(key, mx, my):
    global game_active
    if key == b'\x1b':
        sys.exit(0)
    if not game_active:
        if key == b'r': reset_game()
        return
    if key == b'1': player["weapon"] = 0
    elif key == b'2': player["weapon"] = 1
    elif key == b'3': player["weapon"] = 2
    elif key == b'r': reset_game()
    elif key == b'e':
        best = -1; bd = 80.0; start_t = 0.0
        for i, z in enumerate(ziplines):
            d1 = dist3(player["pos"], z["a"])
            d2 = dist3(player["pos"], z["b"])
            if d1 < bd: bd = d1; best = i; start_t = 0.0
            if d2 < bd: bd = d2; best = i; start_t = 1.0
        if best >= 0:
            player["on_zipline"] = True
            player["zip_idx"]    = best
            player["zip_t"]      = start_t
            player["zip_dir"]    = 1 if start_t < 0.5 else -1
    else:
        keys_held.add(key)


def keyboard_up_handler(key, mx, my):
    keys_held.discard(key)


def special_key_handler(key, mx, my):
    if   key == GLUT_KEY_UP:    cam["elevation"]   += 20
    elif key == GLUT_KEY_DOWN:  cam["elevation"]   -= 20
    elif key == GLUT_KEY_LEFT:  cam["orbit_angle"] -= 0.08
    elif key == GLUT_KEY_RIGHT: cam["orbit_angle"] += 0.08


def mouse_handler(btn, state, mx, my):
    global mouse_down
    if btn == GLUT_LEFT_BUTTON:
        mouse_down = (state == GLUT_DOWN)
    elif btn == GLUT_RIGHT_BUTTON and state == GLUT_DOWN:
        cam["mode"] = "overview" if cam["mode"] == "cockpit" else "cockpit"


first_mouse = True

def passive_motion(x, y):
    """FIX: improved warp guard — reject any delta > 100px to prevent
    the giant-spin glitch that occurred right after glutWarpPointer."""
    global last_mx, last_my, first_mouse
    if first_mouse or last_mx is None:
        last_mx, last_my = x, y
        first_mouse = False
        return
    dx = x - last_mx
    dy = y - last_my
    # FIX: tighter threshold (was 150) and also guard after warp
    if abs(dx) > 80 or abs(dy) > 80:
        last_mx, last_my = x, y
        return
    last_mx, last_my = x, y
    player["facing"] -= dx * MOUSE_SENS
    player["pitch"]  -= dy * MOUSE_SENS
    player["pitch"]   = clampf(player["pitch"], -85.0, 85.0)
    EDGE = 80
    if x < EDGE or x > WIN_W - EDGE or y < EDGE or y > WIN_H - EDGE:
        glutWarpPointer(center_x, center_y)
        # FIX: reset last position AFTER warp so next event won't see huge delta
        last_mx, last_my = center_x, center_y


# ─── Game Tick ──────────────────────────────────────────────────────
def tick_game(value):
    global last_time_ms, game_active, game_won
    now = glutGet(GLUT_ELAPSED_TIME)
    dt  = (now - last_time_ms) / 1000.0
    last_time_ms = now
    if dt <= 0.0:   dt = 1.0 / TARGET_FPS
    if dt > 0.05:   dt = 0.05

    if game_active:
        update_pulse(dt)
        update_weapons(dt)
        update_player(dt)
        update_bullets(dt)
        update_enemies(dt)
        update_boss(dt)
        update_props(dt)
        update_objective()
        if (current_level == NUM_LEVELS - 1
            and boss is not None and not boss["alive"]
            and not game_won):
            game_won = True
        # FIX: game over triggers when lives are exhausted (hp goes to 0 with no lives)
        if player["hp"] <= 0 and player["lives"] <= 0:
            game_active = False

    glutPostRedisplay()
    glutTimerFunc(FRAME_MS, tick_game, 0)


# ─── Render ─────────────────────────────────────────────────────────
def render():
    glClearColor(0.0, 0.0, 0.0, 1.0)
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT)
    glLoadIdentity()

    draw_sky()      # 2-D gradient before 3-D, depth write OFF

    setup_camera()

    # Restore canonical depth state for 3-D pass
    glDepthFunc(GL_LEQUAL)              # NEW: GL_LEQUAL gives cleaner coplanar render
    glDepthMask(GL_TRUE)
    glEnable(GL_DEPTH_TEST)

    draw_ground()
    draw_decor()
    draw_rooftops()
    draw_ziplines()
    draw_checkpoint()
    draw_portal()
    draw_props()
    draw_hostiles()
    draw_boss()
    draw_projectiles()  # additive blend, depth write OFF inside

    draw_hud()          # depth test OFF, depth write OFF inside
    glutSwapBuffers()


# ─── Entry Point ────────────────────────────────────────────────────
def main():
    global last_time_ms, center_x, center_y
    glutInit()
    glutInitDisplayMode(GLUT_DOUBLE | GLUT_RGB | GLUT_DEPTH)
    glutInitWindowSize(WIN_W, WIN_H)
    glutInitWindowPosition(60, 60)
    glutCreateWindow(b"Rooftop Shooter")

    # ── Depth ───────────────────────────────────────────────────────
    glEnable(GL_DEPTH_TEST)
    glDepthFunc(GL_LEQUAL)              # NEW: GL_LEQUAL — default GL_LESS can
                                        # cause self-occlusion on coplanar polys

    # ── Lighting ────────────────────────────────────────────────────
    setup_lighting()

    # ── Fog ─────────────────────────────────────────────────────────
    glEnable(GL_FOG)
    glFogi(GL_FOG_MODE, GL_EXP2)
    glFogfv(GL_FOG_COLOR, (0.68, 0.74, 0.84, 1.0))
    glFogf(GL_FOG_DENSITY, 0.00055)

    # ── Line & point quality ────────────────────────────────────────
    glHint(GL_LINE_SMOOTH_HINT,  GL_NICEST)
    glHint(GL_POINT_SMOOTH_HINT, GL_NICEST)
    glHint(GL_PERSPECTIVE_CORRECTION_HINT, GL_NICEST)

    # ── Blend default state (disabled; enabled per draw call) ───────
    glBlendFunc(GL_SRC_ALPHA, GL_ONE_MINUS_SRC_ALPHA)

    glutDisplayFunc(render)
    glutKeyboardFunc(keyboard_handler)
    glutKeyboardUpFunc(keyboard_up_handler)
    glutSpecialFunc(special_key_handler)
    glutMouseFunc(mouse_handler)
    glutPassiveMotionFunc(passive_motion)
    glutMotionFunc(passive_motion)
    glutSetCursor(GLUT_CURSOR_NONE)

    build_level(0)
    last_time_ms = glutGet(GLUT_ELAPSED_TIME)
    center_x, center_y = WIN_W // 2, WIN_H // 2
    glutWarpPointer(center_x, center_y)

    glutTimerFunc(FRAME_MS, tick_game, 0)
    glutMainLoop()


if __name__ == "__main__":
    main()
