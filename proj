def draw_enemies():
    for e in enemies:
        if not e["alive"]:
            continue
        glColor3f(0.90, 0.10, 0.10)
        solid_box(e["pos"][0], e["pos"][1], e["pos"][2], 18, 18, 22)
        # simple "eye"
        glColor3f(1, 1, 0)
        fx_e = player["pos"][0] - e["pos"][0]
        fy_e = player["pos"][1] - e["pos"][1]
        dm = math.sqrt(fx_e*fx_e + fy_e*fy_e + 1e-9)
        glPushMatrix()
        glTranslatef(e["pos"][0] + (fx_e/dm)*9,
                     e["pos"][1] + (fy_e/dm)*9,
                     e["pos"][2] + 6)
        glutSolidSphere(3, 5, 5)
        glPopMatrix()


