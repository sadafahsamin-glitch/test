# ─── Math Helpers ───────────────────────────────────────────────────
def clampf(v, lo, hi):
    return lo if v < lo else hi if v > hi else v

def dist3(a, b):
    dx, dy, dz = a[0]-b[0], a[1]-b[1], a[2]-b[2]
    return math.sqrt(dx*dx + dy*dy + dz*dz)

def dist2(a, b):
    dx, dy = a[0]-b[0], a[1]-b[1]
    return math.sqrt(dx*dx + dy*dy)

def unit3(v):
    m = math.sqrt(v[0]*v[0] + v[1]*v[1] + v[2]*v[2])
    if m < 1e-6: return [0.0, 0.0, 0.0]
    return [v[0]/m, v[1]/m, v[2]/m]

def facing_vec():
    ry = math.radians(player["facing"])
    rp = math.radians(player["pitch"])
    cp = math.cos(rp)
    return [math.cos(ry)*cp, math.sin(ry)*cp, math.sin(rp)]


# ─── Lighting Setup ─────────────────────────────────────────────────
def setup_lighting():
    glEnable(GL_LIGHTING)
    glEnable(GL_LIGHT0)
    glEnable(GL_COLOR_MATERIAL)
    glColorMaterial(GL_FRONT_AND_BACK, GL_AMBIENT_AND_DIFFUSE)
    glLightModelfv(GL_LIGHT_MODEL_AMBIENT, (0.18, 0.20, 0.28, 1.0))

    # Sun — warm directional light from upper-left
    glLightfv(GL_LIGHT0, GL_POSITION, (500.0, 300.0, 900.0, 1.0))
    glLightfv(GL_LIGHT0, GL_DIFFUSE,  (1.0,  0.95, 0.82, 1.0))
    glLightfv(GL_LIGHT0, GL_SPECULAR, (0.6,  0.55, 0.45, 1.0))
    glLightfv(GL_LIGHT0, GL_AMBIENT,  (0.0,  0.0,  0.0,  1.0))

    # Cool fill light from below — sky bounce
    glEnable(GL_LIGHT1)
    glLightfv(GL_LIGHT1, GL_POSITION, (0.0, 0.0, -1.0, 0.0))
    glLightfv(GL_LIGHT1, GL_DIFFUSE,  (0.07, 0.10, 0.18, 1.0))
    glLightfv(GL_LIGHT1, GL_AMBIENT,  (0.0,  0.0,  0.0,  1.0))

    glShadeModel(GL_SMOOTH)
    glEnable(GL_NORMALIZE)


# ─── Geometry Helpers ───────────────────────────────────────────────
def place_box(cx, cy, cz, w, h, d, rgb):
    glPushMatrix()
    glTranslatef(cx, cy, cz)
    glScalef(w, h, d)
    glColor3fv(rgb)
    glutSolidCube(1.0)
    glPopMatrix()


def place_ball(cx, cy, cz, r, rgb):
    q = gluNewQuadric()
    gluQuadricNormals(q, GLU_SMOOTH)
    glPushMatrix()
    glTranslatef(cx, cy, cz)
    glColor3fv(rgb)
    gluSphere(q, r, 18, 18)
    glPopMatrix()
    gluDeleteQuadric(q)


# ─── HUD Text ───────────────────────────────────────────────────────
def hud_print(sx, sy, msg, rgb=(1.0, 1.0, 1.0), font=GLUT_BITMAP_HELVETICA_18):
    glColor3f(*rgb)
    glMatrixMode(GL_PROJECTION); glPushMatrix(); glLoadIdentity()
    gluOrtho2D(0, WIN_W, 0, WIN_H)
    glMatrixMode(GL_MODELVIEW);  glPushMatrix(); glLoadIdentity()
    glRasterPos2f(sx, sy)
    for c in msg:
        glutBitmapCharacter(font, ord(c))
    glPopMatrix(); glMatrixMode(GL_PROJECTION); glPopMatrix()
    glMatrixMode(GL_MODELVIEW)


