def display():
    global last_t, dt
    now = time.time()
    dt  = min(now - last_t, 0.05)
    last_t = now

    update_all()

    glClearColor(0.04, 0.04, 0.12, 1.0)
    glClear(GL_COLOR_BUFFER_BIT | GL_DEPTH_BUFFER_BIT)
    glLoadIdentity()

    # camera: behind and above player
    px, py, pz = player["pos"]
    fx, fy     = player["facing"][0], player["facing"][1]
    cx = px - fx*280
    cy = py - fy*280
    cz = pz + 190
    gluLookAt(cx, cy, cz, px, py, pz, 0, 0, 1)

    # infinite-looking dark ground
    glDisable(GL_LIGHTING)
    glColor3f(0.04, 0.04, 0.08)
    glBegin(GL_QUADS)
    glVertex3f(-2000, -2000, -15)
    glVertex3f( 2000, -2000, -15)
    glVertex3f( 2000,  2000, -15)
    glVertex3f(-2000,  2000, -15)
    glEnd()

    # faint grid on ground
    glColor3f(0.08, 0.08, 0.14)
    glBegin(GL_LINES)
    for i in range(-10, 11):
        glVertex3f(i*200, -2000, -14); glVertex3f(i*200,  2000, -14)
        glVertex3f(-2000, i*200, -14); glVertex3f( 2000,  i*200, -14)
    glEnd()
    glEnable(GL_LIGHTING)

    draw_rooftops_scene()
    draw_anchors()
    draw_player()
    draw_enemies()
    draw_hook()
    draw_projectiles()
    draw_boss()
    draw_hud()

    if game_state == "dead":
        draw_overlay_text("YOU DIED\nPress R to restart", (1.0, 0.25, 0.25))
    elif game_state == "win":
        draw_overlay_text(f"VICTORY!\nWaves cleared: {wave}   Kills: {kills}\nPress R to play again",
                          (0.25, 1.0, 0.35))

    glutSwapBuffers()


def idle():
    glutPostRedisplay()


def reshape(w, h):
    global W, H
    W, H = max(w, 1), max(h, 1)
    glViewport(0, 0, W, H)
    glMatrixMode(GL_PROJECTION)
    glLoadIdentity()
    gluPerspective(58.0, W/H, 2.0, 4000.0)
    glMatrixMode(GL_MODELVIEW)


