# CONSTANTS & GLOBALS
# ─────────────────────────────────────────────
W, H = 900, 650
GRAVITY        = 0.45
JUMP_VEL       = 13.0
PLAYER_SPEED   = 170.0
HOOK_SPEED     = 18.0
HOOK_RANGE     = 550.0
TILE_HP_MAX    = 3
TILE_N         = 5        # tiles per side per rooftop
BOSS_MAX_HP    = 5

player = {
    "pos":      [0.0, 0.0, 110.0],
    "vel":      [0.0, 0.0,   0.0],
    "on_ground": True,
    "hp":       5,
    "angle":    0.0,           # yaw degrees
    "facing":   [1.0, 0.0, 0.0],
    "iframes":  0,             # invincibility frames after hit
}

hook = {
    "active":   False,
    "pos":      [0.0, 0.0, 0.0],
    "dir":      [0.0, 0.0, 0.0],
    "attached": False,
    "target":   None,
}

boss = {
    "active":          False,
    "pos":             [0.0, 0.0, 500.0],
    "target_pos":      [0.0, 0.0, 500.0],
    "hp":              BOSS_MAX_HP,
    "propeller_angle": 0.0,
    "state":           "idle",   # idle | locking | moving
    "laser_active":    False,
    "lock_timer":      0,
    "move_timer":      90,
}

rooftops    = []   # list of dicts
anchor_pts  = []   # mid-air grapple anchors
projectiles = []
enemies     = []
tiles       = {}   # index → 2-D list of HP values

wind       = [0.18, 0.06]
keys_held  = set()
