# WORLD SETUP
# ─────────────────────────────────────────────
def init_world():
    global rooftops, anchor_pts, enemies

    # 5×5 grid of buildings at varied heights
    layout = [
        # (cx,  cy,   cz,  size)
        (-420,-420, 220, 155), (-210,-420, 120, 140), (0,  -420, 290, 160),
        ( 210,-420, 180, 145), ( 420,-420, 150, 140),

        (-420,-210, 110, 140), (-210,-210, 330, 160), (0,  -210, 170, 140),
        ( 210,-210, 260, 155), ( 420,-210, 210, 145),

        (-420,   0, 190, 155), (-210,   0, 160, 140), (0,     0,  90, 165),  # idx 12 = start
        ( 210,   0, 240, 140), ( 420,   0, 310, 155),

        (-420, 210, 270, 145), (-210, 210, 200, 155), (0,   210, 310, 145),
        ( 210, 210, 130, 155), ( 420, 210, 200, 140),

        (-420, 420, 150, 140), (-210, 420, 280, 155), (0,   420, 210, 145),
        ( 210, 420, 160, 155), ( 420, 420, 250, 140),
    ]

    for i, (cx, cy, cz, sz) in enumerate(layout):
        rooftops.append({"x": float(cx), "y": float(cy),
                         "z": float(cz), "size": float(sz), "id": i})
        tiles[i] = [[TILE_HP_MAX]*TILE_N for _ in range(TILE_N)]

    # mid-air antenna anchors (puzzle nodes)
    for ax, ay, az in [(-315,-420,350), (105,-420,370),
                        (-315, 210,340), (315,   0,400), (0, 315,420)]:
        anchor_pts.append({"x": float(ax), "y": float(ay), "z": float(az)})

    # player starts on centre rooftop (idx 12)
    s = rooftops[12]
    player["pos"] = [s["x"], s["y"], s["z"] + 15.0]

    spawn_enemies(wave)


def spawn_enemies(n_wave):
    global enemies
    enemies = []
    count = 3 + n_wave
    for _ in range(count):
        r = random.choice(rooftops)
        enemies.append({
            "pos":         [r["x"] + random.uniform(-30, 30),
                            r["y"] + random.uniform(-30, 30),
                            r["z"] + 14.0],
            "hp":          2,
            "shoot_timer": random.randint(70, 130),
            "alive":       True,
        })

