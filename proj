def draw_rooftop(R):
    cx, cy = R["cx"], R["cy"]
    sx, sy = R["sx"], R["sy"]
    top    = R["top"]
    col    = R["color"]

    glEnable(GL_LIGHTING)
    side_dark = (col[0]*0.72, col[1]*0.72, col[2]*0.72)
    glColor3f(*side_dark)

    # Side walls
    glNormal3f(-1, 0, 0)
    glBegin(GL_QUADS)
    glVertex3f(cx-sx, cy-sy, 0);   glVertex3f(cx-sx, cy+sy, 0)
    glVertex3f(cx-sx, cy+sy, top); glVertex3f(cx-sx, cy-sy, top)
    glEnd()

    glNormal3f(1, 0, 0)
    glBegin(GL_QUADS)
    glVertex3f(cx+sx, cy+sy, 0);   glVertex3f(cx+sx, cy-sy, 0)
    glVertex3f(cx+sx, cy-sy, top); glVertex3f(cx+sx, cy+sy, top)
    glEnd()

    glNormal3f(0, -1, 0)
    glBegin(GL_QUADS)
    glVertex3f(cx+sx, cy-sy, 0);   glVertex3f(cx-sx, cy-sy, 0)
    glVertex3f(cx-sx, cy-sy, top); glVertex3f(cx+sx, cy-sy, top)
    glEnd()

    glNormal3f(0, 1, 0)
    glBegin(GL_QUADS)
    glVertex3f(cx-sx, cy+sy, 0);   glVertex3f(cx+sx, cy+sy, 0)
    glVertex3f(cx+sx, cy+sy, top); glVertex3f(cx-sx, cy+sy, top)
    glEnd()

    # FIX: polygon offset to prevent z-fighting between tile quads and
    # anything else at the same depth (roof top surface coplanar fighting).
    glEnable(GL_POLYGON_OFFSET_FILL)
    glPolygonOffset(-1.0, -1.0)         # pull tiles slightly toward camera

    tsx = (2*sx) / R["gx"]
    tsy = (2*sy) / R["gy"]
    glNormal3f(0, 0, 1)
    glBegin(GL_QUADS)
    for iy in range(R["gy"]):
        for ix in range(R["gx"]):
            tile = R["tiles"][iy][ix]
            if tile["dead"]: continue
            tcx = cx - sx + tsx*(ix + 0.5)
            tcy = cy - sy + tsy*(iy + 0.5)
            shade = 0.62 if tile["hp"] < 3 else 1.0
            glColor3f(col[0]*shade, col[1]*shade, col[2]*shade)
            glVertex3f(tcx - tsx*0.48, tcy - tsy*0.48, top)
            glVertex3f(tcx + tsx*0.48, tcy - tsy*0.48, top)
            glVertex3f(tcx + tsx*0.48, tcy + tsy*0.48, top)
            glVertex3f(tcx - tsx*0.48, tcy + tsy*0.48, top)
    glEnd()

    glDisable(GL_POLYGON_OFFSET_FILL)   # FIX: restore — don't leak offset

    # Parapet rim
    rim_col = (col[0]*0.55, col[1]*0.55, col[2]*0.55)
    rim_h   = 6.0
    rim_w   = 5.0
    glColor3f(*rim_col)

    def rim_box(rx, ry, rw, rh):
        glPushMatrix()
        glTranslatef(rx, ry, top + rim_h * 0.5)
        glScalef(rw, rim_w, rim_h)
        glutSolidCube(1.0)
        glPopMatrix()

    rim_box(cx,      cy + sy, sx*2, rim_w)
    rim_box(cx,      cy - sy, sx*2, rim_w)
    rim_box(cx + sx, cy,      rim_w, sy*2)
    rim_box(cx - sx, cy,      rim_w, sy*2)

    # Rooftop A/C vents
    vent_col = (0.32, 0.32, 0.36)
    rng = random.Random(int(cx*7 + cy*13))
    for _ in range(3):
        vx = cx + rng.uniform(-sx*0.55, sx*0.55)
        vy = cy + rng.uniform(-sy*0.55, sy*0.55)
        glColor3f(*vent_col)
        glPushMatrix()
        glTranslatef(vx, vy, top + 5)
        glScalef(14, 10, 10)
        glutSolidCube(1.0)
        glPopMatrix()


def draw_rooftops():
    for R in rooftops:
        draw_rooftop(R)


